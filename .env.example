# Cookie Butler 环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置

# ================================
# 可选配置（所有配置都是可选的）
# ================================

# 允许的CORS源（可选，用于额外的域名）
# 应用会自动处理localhost和部署域名，只有需要额外域名时才设置
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 服务器端口（默认3000）
# PORT=3000

# 环境标识（默认production）
# NODE_ENV=production

# API请求超时时间（毫秒，默认15000）
# API_TIMEOUT=15000

# 会话密钥过期时间（毫秒，默认300000=5分钟）
# SESSION_TTL=300000

# Telegram Bot Token（配置后会原生启用 TG 机器人）
# TELEGRAM_BOT_TOKEN=123456:ABCDEF_your_bot_token

# 允许使用机器人的私聊 chat_id 列表，多个用逗号分隔；留空表示不限制
# TELEGRAM_BOT_ALLOWED_CHAT_IDS=123456789,987654321

# Telegram getUpdates 长轮询超时时间（秒，默认25）
# TELEGRAM_BOT_UPDATE_TIMEOUT=25

# 登录状态轮询间隔（毫秒，默认3000）
# TELEGRAM_BOT_STATUS_INTERVAL=3000

# TG 侧二维码轮询超时时间（毫秒，默认300000）
# TELEGRAM_BOT_QR_TIMEOUT=300000

# ================================
# 说明
# ================================
# 应用会自动处理CORS配置：
# - 开发环境：自动允许localhost
# - 生产环境：自动使用部署域名（如Vercel URL）
# - ALLOWED_ORIGINS：仅在需要额外域名时设置
#
# Telegram 机器人说明：
# - 仅支持私聊使用
# - 推荐配合 TELEGRAM_BOT_ALLOWED_CHAT_IDS 做访问白名单
# - 程序启动时会自动读取项目根目录下的 .env 文件
